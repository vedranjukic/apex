{
  "name": "@apex/cli",
  "version": "0.1.0",
  "description": "Apex CLI rewritten in TypeScript with Bun",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:binary": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/apex-linux-x64",
    "build:binary:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/apex-darwin-arm64",
    "build:binary:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist/apex-darwin-x64",
    "build:all": "bun run build:binary && bun run build:binary:darwin-arm64 && bun run build:binary:darwin-x64",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.17",
    "@types/react": "18.2.0",
    "@types/ws": "^8.5.10",
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "ink": "4.4.1",
    "inquirer": "^9.2.15",
    "neo-blessed": "^0.2.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "react": "18.2.0",
    "terminal-kit": "^3.1.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "apex",
    "cli",
    "ai",
    "development",
    "automation"
  ],
  "author": "Apex Team",
  "license": "MIT",
  "bin": {
    "apex": "./dist/apex"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
