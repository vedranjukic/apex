{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cli/src",
  "projectType": "application",
  "tags": ["scope:cli", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build src/main.ts --outdir dist --target bun",
        "cwd": "apps/cli"
      },
      "configurations": {
        "production": {
          "command": "bun build src/main.ts --outdir dist --target bun --minify"
        }
      }
    },
    "build:binary": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/build.sh",
        "cwd": "apps/cli"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --watch src/main.ts",
        "cwd": "apps/cli"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/cli"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test",
        "cwd": "apps/cli"
      }
    }
  }
}