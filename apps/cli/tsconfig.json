{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "jsx": "react",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "bun-types"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "references": [
    {
      "path": "../../libs/orchestrator"
    }
  ]
}