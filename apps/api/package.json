{
  "name": "@apex/api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "dependsOn": ["@apex/mobile-dashboard:build"],
        "options": {
          "command": "bun build src/main.ts --target=bun --outdir=dist --sourcemap --external cpu-features --external better-sqlite3 --external ssh2",
          "cwd": "apps/api"
        }
      },
      "serve": {
        "continuous": true,
        "executor": "nx:run-commands",
        "defaultConfiguration": "development",
        "options": {
          "command": "PORT=6000 bun run --watch src/main.ts",
          "cwd": "apps/api"
        }
      }
    }
  },
  "dependencies": {
    "drizzle-orm": "*",
    "elysia": "*"
  }
}
