{
  "name": "@apex/api-e2e",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "nx": {
    "implicitDependencies": [
      "@apex/api"
    ],
    "targets": {
      "e2e": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "command": "npx jest --config apps/api-e2e/jest.config.js --runInBand --passWithNoTests",
          "cwd": "{workspaceRoot}"
        },
        "dependsOn": [
          "@apex/api:build"
        ]
      }
    }
  }
}
