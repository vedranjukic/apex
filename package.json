{
  "name": "@apex/source",
  "version": "0.0.1",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "npx nx run-many --target=build --all",
    "build:cli": "npx nx run cli:build",
    "build:cli:binary": "npx nx run cli:build:binary",
    "cli": "cd apps/cli && bun src/main.ts",
    "build:api": "npx nx build @apex/api",
    "build:dashboard": "npx nx build @apex/dashboard",
    "serve": "npx nx run-many --target=serve --projects=@apex/api,@apex/dashboard --parallel=2",
    "serve:api": "npx nx serve @apex/api",
    "serve:dashboard": "npx nx serve @apex/dashboard",
    "desktop:dev": "npx nx build @apex/api --skip-nx-cache && npx nx build @apex/dashboard --skip-nx-cache && cd apps/desktop && npx electrobun build && npx electrobun dev",
    "desktop:build": "npx nx build @apex/api && npx nx build @apex/dashboard && node scripts/build-desktop.js --env dev",
    "desktop:build:canary": "npx nx build @apex/api && npx nx build @apex/dashboard && node scripts/build-desktop.js --env canary",
    "desktop:package": "npx nx build @apex/api && npx nx build @apex/dashboard && node scripts/build-desktop.js --env stable",
    "test:agent-retry": "cd apps/api && APEX_TEST_AGENT_TIMEOUT_MS=100 npx vitest run",
    "test:bridge-adapters": "cd libs/orchestrator && npx vitest run",
    "test:agent-retry-e2e": "APEX_E2E_TEST=1 npx nx e2e @apex/api-e2e -- --testPathPatterns=agent-retry",
    "test:multi-agent-e2e": "npx nx e2e @apex/api-e2e -- --testPathPatterns=multi-agent.spec",
    "test:ask-user-e2e": "npx nx e2e @apex/api-e2e -- --testPathPatterns=ask-user",
    "test:secrets-proxy-e2e": "npx nx e2e @apex/api-e2e -- --testPathPatterns='secrets-proxy\\.spec'",
    "test:settings-e2e": "npx nx e2e @apex/api-e2e -- --testPathPatterns=settings-api.e2e-spec.ts",
    "test:settings-dashboard-e2e": "npx nx e2e @apex/api-e2e -- --testPathPatterns=settings-dashboard-integration.e2e-spec.ts",
    "test:settings-type-safety-e2e": "npx nx e2e @apex/api-e2e -- --testPathPatterns=settings-type-safety.e2e-spec.ts",
    "test:settings-all-e2e": "bun apps/api-e2e/src/settings-e2e-runner.ts",
    "test:github-token-e2e": "npx nx e2e @apex/api-e2e -- --testPathPatterns='github-token-proxy'",
    "test:proxy-projects-e2e": "DAYTONA_API_KEY=${DAYTONA_API_KEY_E2E:-$DAYTONA_API_KEY} npx nx e2e @apex/api-e2e -- --testPathPatterns=proxy-projects-daytona",
    "test:secrets-proxy-daytona-e2e": "DAYTONA_API_KEY=${DAYTONA_API_KEY_E2E:-$DAYTONA_API_KEY} npx nx e2e @apex/api-e2e -- --testPathPatterns=secrets-proxy-daytona",
    "test:agent-interaction-e2e": "DAYTONA_API_KEY=${DAYTONA_API_KEY_E2E:-$DAYTONA_API_KEY} npx nx e2e @apex/api-e2e -- --testPathPatterns=agent-interaction --testPathIgnorePatterns='multi-agent|ask-user|agent-retry|secrets-proxy'",
    "test:bridge-replay-e2e": "DAYTONA_API_KEY=${DAYTONA_API_KEY_E2E:-$DAYTONA_API_KEY} npx nx e2e @apex/api-e2e -- --testPathPatterns=bridge-replay",
    "test:replay-backfill-e2e": "DAYTONA_API_KEY=${DAYTONA_API_KEY_E2E:-$DAYTONA_API_KEY} npx nx e2e @apex/api-e2e -- --testPathPatterns=replay-backfill",
    "test:e2e": "DAYTONA_API_KEY=${DAYTONA_API_KEY_E2E:-$DAYTONA_API_KEY} APEX_E2E_TEST=1 npx nx e2e @apex/api-e2e"
  },
  "private": true,
  "dependencies": {
    "@apex/orchestrator": "*",
    "@apex/shared": "*",
    "@codingame/esbuild-import-meta-url-plugin": "^1.0.3",
    "@codingame/monaco-vscode-css-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-go-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-html-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-java-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-javascript-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-json-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-markdown-basics-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-python-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-rollup-vsix-plugin": "^28.4.1",
    "@codingame/monaco-vscode-rust-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-typescript-basics-default-extension": "^25.1.2",
    "@codingame/monaco-vscode-yaml-default-extension": "^25.1.2",
    "@daytonaio/sdk": "^0.158.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@typefox/monaco-editor-react": "^7.7.0",
    "@types/node-forge": "^1.3.14",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "lucide-react": "^0.564.0",
    "monaco-languageclient": "^10.7.0",
    "node-forge": "^1.3.3",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1",
    "tar": "^7.5.12",
    "ws": "^8.20.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@nx/devkit": "22.5.1",
    "@nx/js": "22.5.1",
    "@nx/node": "22.5.1",
    "@nx/playwright": "22.5.1",
    "@nx/react": "22.5.1",
    "@nx/vite": "22.5.1",
    "@nx/web": "22.5.1",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "^0.2.38",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.40",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.0",
    "better-sqlite3": "^12.6.2",
    "bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "electrobun": "latest",
    "jest": "^30.0.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.5.1",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "resolutions": {
    "vite": "^7.0.0"
  },
  "build": {
    "note": "Desktop packaging is handled by Electrobun CLI. See apps/desktop/electrobun.config.ts"
  }
}
