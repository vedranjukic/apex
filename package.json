{
  "name": "@apex/source",
  "version": "0.0.1",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "npx nx run-many --target=build --all",
    "build:cli": "cd apps/cli && go build -o bin/apex .",
    "build:api": "npx nx build @apex/api",
    "build:dashboard": "npx nx build @apex/dashboard",
    "serve": "npx nx run-many --target=serve --projects=@apex/api,@apex/dashboard --parallel=2",
    "serve:api": "npx nx serve @apex/api",
    "serve:dashboard": "npx nx serve @apex/dashboard",
    "desktop:dev": "npx nx build @apex/api && npx nx build @apex/dashboard && cd apps/desktop && yarn start",
    "desktop:build": "npx nx build @apex/api && npx nx build @apex/dashboard && node scripts/build-desktop.js --env dev",
    "desktop:build:canary": "npx nx build @apex/api && npx nx build @apex/dashboard && node scripts/build-desktop.js --env canary",
    "desktop:package": "npx nx build @apex/api && npx nx build @apex/dashboard && node scripts/build-desktop.js --env stable",
    "test:agent-retry": "cd apps/api && APEX_TEST_AGENT_TIMEOUT_MS=100 npx vitest run",
    "test:bridge-adapters": "cd libs/orchestrator && npx vitest run",
    "test:agent-retry-e2e": "APEX_E2E_TEST=1 npx nx e2e @apex/api-e2e --testPathPattern=agent-retry",
    "test:multi-agent-e2e": "npx nx e2e @apex/api-e2e --testPathPattern=multi-agent.spec",
    "test:ask-user-e2e": "npx nx e2e @apex/api-e2e --testPathPattern=ask-user",
    "test:create-project-e2e": "npx nx e2e @apex/cli-e2e --testPathPattern=create-project",
    "test:secrets-proxy-e2e": "npx nx e2e @apex/api-e2e --testPathPattern=secrets-proxy.spec"
  },
  "private": true,
  "dependencies": {
    "@apex/orchestrator": "*",
    "@apex/shared": "*",
    "@daytonaio/sdk": "0.131.0-alpha.2",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@monaco-editor/react": "^4.7.0",
    "@types/node-forge": "^1.3.14",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "lucide-react": "^0.564.0",
    "node-forge": "^1.3.3",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1",
    "tar": "^7.5.12",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@nx/devkit": "22.5.1",
    "@nx/js": "22.5.1",
    "@nx/node": "22.5.1",
    "@nx/playwright": "22.5.1",
    "@nx/react": "22.5.1",
    "@nx/vite": "22.5.1",
    "@nx/web": "22.5.1",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "^0.2.38",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.40",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.0",
    "better-sqlite3": "^12.6.2",
    "bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "electrobun": "latest",
    "jest": "^30.0.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.5.1",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "resolutions": {
    "vite": "^7.0.0"
  },
  "build": {
    "note": "Desktop packaging is handled by Electrobun CLI. See apps/desktop/electrobun.config.ts"
  }
}
